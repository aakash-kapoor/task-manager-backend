datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  boards    Board[]
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Board {
  id        String   @id @default(uuid())
  title     String
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String
  priority    String
  dueDate     DateTime?
  board       Board    @relation(fields: [boardId], references: [id])
  boardId     String
  assignedTo  User?    @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt   DateTime @default(now())
}